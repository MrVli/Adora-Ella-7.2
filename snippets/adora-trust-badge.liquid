{%- liquid
  assign badge_text = text
  assign badge_icon = icon
  assign badge_icon_alt = icon_alt | default: badge_text | escape
  assign badge_icon_size = icon_size | default: 22
  assign badge_link = link
  assign badge_show_text = show_text
  assign badge_show_icon = show_icon

  if badge_show_text == nil
    assign badge_show_text = true
  endif

  if badge_show_icon == nil
    assign badge_show_icon = true
  endif

  assign badge_tag = 'span'
  if badge_link != blank
    assign badge_tag = 'a'
  endif
-%}

{%- if badge_text != blank or badge_icon != blank -%}
  <{{ badge_tag }}
    class="adora-badge adora-trust-badge"
    {% if badge_link != blank %}href="{{ badge_link }}"{% endif %}
    style="--adora-trust-badge-icon-size: {{ badge_icon_size }}px;"
  >
    {%- if badge_show_icon and badge_icon != blank -%}
      {{ badge_icon | image_url: width: 96 | image_tag: class: 'adora-trust-badge__icon', alt: badge_icon_alt, loading: 'lazy', widths: '24, 48, 72, 96', sizes: badge_icon_size | append: 'px' }}
    {%- endif -%}

    {%- if badge_show_text and badge_text != blank -%}
      <span class="adora-trust-badge__text">{{ badge_text | escape }}</span>
    {%- endif -%}
  </{{ badge_tag }}>
{%- endif -%}
