{% comment %}
  Renders a megamenu for the header.

  Usage:
  {% render 'header-mega-menu' %}
{% endcomment %}

{%- liquid
  assign bl_stts = block.settings

  assign section_fetch = section_fetch | default: false
  if section.index == nil
    assign section_fetch = true
  endif
-%}

{%- unless section_fetch -%}
  <div
    id="MegaMenu-Content-{{ section.id }}-{{ forloopIndex }}-{{ block_id }}"
    class="list-menu--wrapper"
    tabindex="-1"
    style="--columns-count: {{ bl_stts.grid }}; --gap-x: 1.6rem; --gap-y: 1.6rem"
  ></div>
{%- else -%}
  <div
    id="MegaMenu-Content-{{ section.id }}-{{ forloopIndex }}-{{ block_id }}"
    class="list-menu--wrapper"
    tabindex="-1"
    style="--columns-count: {{ bl_stts.grid }}; --gap-x: 1.6rem; --gap-y: 1.6rem"
  >
    <div class="mega-menu__container page-width page-width--{{ bl_stts.width }} flex items-start justify-between flex-wrap xl:flex-nowrap">
      <ul
        class="mega-menu__list header__mega-submenu{% if link.levels == 1 %} mega-menu__list--condensed{% endif %}"
        role="list"
        id="MegaMenu-List-{{ section.id }}-{{ forloopIndex }}"
      >
        {%- render 'mega-menu-list-columns',
          link: link,
          columns_count: bl_stts.grid,
          keys: keys,
          sec_settings: sec_settings,
          highlight_color: highlight_color
        -%}
      </ul>
      {%- liquid
        assign has_mega_menu_images = false
        if bl_stts.show_promotion_banner
          if bl_stts.image_1 != blank or bl_stts.image_2 != blank or bl_stts.image_3 != blank
            assign has_mega_menu_images = true
            assign mega_menu_images_size = 0
            assign image_index = 0
          endif
        endif
      -%}
      {%- if has_mega_menu_images == true -%}
        {%- for i in (1..3) -%}
          {%- capture capture_image -%}image_{{ i }}{%- endcapture -%}
          {%- liquid
            assign image = bl_stts[capture_image]
            if image != blank
              assign mega_menu_images_size = mega_menu_images_size | plus: 1
            endif
          -%}
        {%- endfor -%}
        {%- liquid
          assign is_one_column = false
          if bl_stts.image_3 != blank
            if bl_stts.image_1 == blank and bl_stts.image_2 == blank
              assign is_one_column = true
            endif
          else
            if bl_stts.image_1 != blank or bl_stts.image_2 != blank
              assign is_one_column = true
            endif
          endif
        -%}
        <div
          class="
            mega-menu__collage collage collage-2-columns grid contains-card contains-card--card
            collage--{{ bl_stts.promotion_banner_layout }}
            collage--{{ mega_menu_images_size }}-items
          "
          style="
            --border-radius: {{ bl_stts.image_corner_radius | divided_by: 10.0 }}rem;
            --border-width: {{ bl_stts.image_border_thickness | divided_by: 10.0 }}rem;
            --gap-x: 1rem;
            --gap-y: 1rem;
            {% if is_one_column %}flex: 0 0 25rem;{% endif %}
          "
        >
          {%- for i in (1..3) -%}
            {%- capture capture_image -%}image_{{ i }}{%- endcapture -%}
            {%- capture capture_link_url -%}link_url_{{ i }}{%- endcapture -%}
            {%- liquid
              assign image = bl_stts[capture_image]
              assign link_url = bl_stts[capture_link_url]
            -%}
            {%- if image != blank -%}
              {%- assign image_index = image_index | plus: 1 -%}
              <div
                class="
                  overflow-hidden
                  collage__item
                  collage__item--image
                  collage__item--{{ image_index }}
                "
              >
                <a
                  class="block relative h-full"
                  {% if link_url != blank %}
                    href="{{ link_url }}"
                  {% else %}
                    role="link" aria-disabled="true"
                  {% endif %}
                >
                  {%- liquid
                    assign ratio = image.aspect_ratio | default: 1
                    assign image_alt = image.alt | default: shop.name | escape
                  -%}
                  <div
                    class="media media--transparent media--adapt relative overflow-hidden h-full"
                    style="--media-adapt-ratio: {{ ratio }};"
                  >
                    {{
                      image
                      | image_url: width: 600
                      | image_tag:
                        loading: 'lazy',
                        widths: '275, 550, 710',
                        sizes: sizes,
                        alt: image_alt,
                        class: 'motion-reduce'
                    }}
                  </div>
                </a>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
{%- endunless -%}
