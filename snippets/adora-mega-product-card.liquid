{%- liquid
  assign card_product = product
  assign product_badge = badge
  assign product_image = card_product.featured_image
-%}

{%- if card_product != blank -%}
  <a class="adora-header__mega-product" href="{{ card_product.url }}">
    <div class="adora-header__mega-product-media">
      {%- if product_badge != blank -%}<span class="adora-header__mega-product-badge">{{ product_badge | escape }}</span>{%- endif -%}
      {%- if product_image != blank -%}
        {{ product_image | image_url: width: 620 | image_tag: class: 'adora-header__mega-product-image', alt: card_product.title, loading: 'lazy', widths: '220, 360, 520, 620', sizes: '(min-width: 990px) 18vw, 70vw' }}
      {%- else -%}
        <div class="adora-header__mega-product-placeholder" aria-hidden="true"><span>{{ card_product.title | slice: 0, 1 | escape }}</span></div>
      {%- endif -%}
    </div>
    <div class="adora-header__mega-product-copy">
      <span class="adora-header__mega-product-title">{{ card_product.title | escape }}</span>
      {%- if card_product.price > 0 -%}<span class="adora-header__mega-product-price">{{ card_product.price | money }}</span>{%- endif -%}
    </div>
  </a>
{%- endif -%}
