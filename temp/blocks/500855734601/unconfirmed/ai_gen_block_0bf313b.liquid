      "max": 1000,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "select",
      "id": "content_vertical_alignment",
      "label": "Vertikale Ausrichtung",
      "options": [
        {
          "value": "flex-start",
          "label": "Oben"
        },
        {
          "value": "center",
          "label": "Mitte"
        },
        {
          "value": "flex-end",
          "label": "Unten"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "content_horizontal_alignment",
      "label": "Horizontale Ausrichtung",
      "options": [
        {
          "value": "flex-start",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Mitte"
        },
        {
          "value": "flex-end",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Textausrichtung",
      "options": [
        {
          "value": "left",
          "label": "Links"
        },
        {
          "value": "center",
          "label": "Mitte"
        },
        {
          "value": "right",
          "label": "Rechts"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Textfarbe",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Typografie"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Unterüberschrift Größe",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "subheading_spacing",
