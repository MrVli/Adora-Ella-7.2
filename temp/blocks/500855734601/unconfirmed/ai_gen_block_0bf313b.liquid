        {
          "value": "image",
          "label": "Bild"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ],
      "default": "image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop Höhe",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile Höhe",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 60
