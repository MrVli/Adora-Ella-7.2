{%- liquid
  assign drawer_id = 'AdoraHeaderOverlayDrawer-' | append: section.id
  assign logo_alt = section.settings.logo_image.alt | default: section.settings.logo_text | default: shop.name | escape
-%}

<header
  class="adora-header-overlay adora-header-overlay--visible adora-header-overlay--solid{% if section.settings.enable_blur_on_scroll %} adora-header-overlay--blur{% endif %}"
  data-adora-header-overlay
  data-homepage="{% if request.page_type == 'index' %}true{% else %}false{% endif %}"
  data-transparent-homepage="{{ section.settings.enable_transparent_on_homepage }}"
  data-hide-on-scroll-down="{{ section.settings.enable_hide_on_scroll_down }}"
  data-show-on-scroll-up="{{ section.settings.enable_show_on_scroll_up }}"
  data-solid-after-scroll="{{ section.settings.enable_solid_after_scroll }}"
  data-scroll-threshold="{{ section.settings.scroll_threshold }}"
  data-drawer-id="{{ drawer_id }}"
  style="
    --adora-header-overlay-height-desktop: {{ section.settings.header_height_desktop }}px;
    --adora-header-overlay-height-mobile: {{ section.settings.header_height_mobile }}px;
    --adora-header-overlay-logo-width-desktop: {{ section.settings.logo_width_desktop }}px;
    --adora-header-overlay-logo-width-mobile: {{ section.settings.logo_width_mobile }}px;
    --adora-header-overlay-transparent-text: {{ section.settings.transparent_text_color }};
    --adora-header-overlay-solid-bg: {{ section.settings.solid_bg_color }};
    --adora-header-overlay-solid-text: {{ section.settings.solid_text_color }};
    --adora-header-overlay-drawer-bg: {{ section.settings.drawer_bg_color }};
    --adora-header-overlay-drawer-text: {{ section.settings.drawer_text_color }};
  "
  {% unless section.settings.enable_header %}hidden{% endunless %}
>
  <div class="adora-header-overlay__inner">
    <div class="adora-header-overlay__mobile-left">
      <button class="adora-header-overlay__burger" type="button" aria-label="Menü öffnen" aria-controls="{{ drawer_id }}" aria-expanded="false" data-adora-header-overlay-burger>
        <span class="adora-header-overlay__burger-lines" aria-hidden="true"><span></span></span>
      </button>
    </div>

    <nav class="adora-header-overlay__nav" aria-label="Hauptnavigation">
      {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
        <ul class="adora-header-overlay__nav-list">
          {%- for link in section.settings.menu.links -%}
            <li><a class="adora-header-overlay__nav-link" href="{{ link.url }}">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    <a class="adora-header-overlay__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {%- if section.settings.logo_image != blank -%}
        {{ section.settings.logo_image | image_url: width: 480 | image_tag: class: 'adora-header-overlay__logo-image', alt: logo_alt, loading: 'eager', widths: '120, 180, 240, 320, 480', sizes: '(min-width: 990px) var(--adora-header-overlay-logo-width-desktop), var(--adora-header-overlay-logo-width-mobile)' }}
      {%- else -%}
        <span class="adora-header-overlay__logo-text">{{ section.settings.logo_text | default: 'ADORA' | escape }}</span>
      {%- endif -%}
    </a>

    <div class="adora-header-overlay__utilities" aria-label="Header Links">
      <ul class="adora-header-overlay__utility-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'utility_link' and block.settings.show_desktop and block.settings.label != blank -%}
            <li {{ block.shopify_attributes }}><a class="adora-header-overlay__utility-link" href="{{ block.settings.url | default: '#' }}">{{ block.settings.label | escape }}</a></li>
          {%- endif -%}
        {%- endfor -%}
        {%- if section.settings.show_search -%}
          <li><a class="adora-header-overlay__utility-link" href="{{ routes.search_url }}">{{ section.settings.search_label | default: 'Search' | escape }}</a></li>
        {%- endif -%}
        {%- if section.settings.show_account and shop.customer_accounts_enabled -%}
          <li><a class="adora-header-overlay__utility-link" href="{{ routes.account_url }}">{{ section.settings.account_label | default: 'Account' | escape }}</a></li>
        {%- endif -%}
        {%- if section.settings.show_cart -%}
          <li><a class="adora-header-overlay__utility-link adora-header-overlay__cart-link" href="{{ routes.cart_url }}">{{ section.settings.cart_label | default: 'Cart' | escape }}{%- if section.settings.show_cart_count -%} <span class="adora-header-overlay__cart-count">({{ cart.item_count }})</span>{%- endif -%}</a></li>
        {%- endif -%}
      </ul>
    </div>

    <div class="adora-header-overlay__mobile-cart">
      {%- if section.settings.show_cart -%}
        <a class="adora-header-overlay__cart-link" href="{{ routes.cart_url }}" aria-label="{{ section.settings.cart_label | default: 'Cart' | escape }}">
          {{ section.settings.cart_label | default: 'Cart' | escape }}{%- if section.settings.show_cart_count -%} <span class="adora-header-overlay__cart-count">({{ cart.item_count }})</span>{%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </div>

  <div class="adora-header-overlay__drawer-backdrop" aria-hidden="true" data-adora-header-overlay-backdrop></div>

  <aside id="{{ drawer_id }}" class="adora-header-overlay__drawer" aria-hidden="true" aria-label="Mobile Navigation" data-adora-header-overlay-drawer>
    <div class="adora-header-overlay__drawer-head">
      <a class="adora-header-overlay__drawer-logo" href="{{ routes.root_url }}">{{ section.settings.logo_text | default: 'ADORA' | escape }}</a>
      <button class="adora-header-overlay__drawer-close" type="button" aria-label="Menü schließen" data-adora-header-overlay-close>×</button>
    </div>

    {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
      <nav class="adora-header-overlay__drawer-nav" aria-label="Mobile Hauptnavigation">
        {%- for link in section.settings.menu.links -%}
          <a class="adora-header-overlay__drawer-link" href="{{ link.url }}">{{ link.title | escape }}</a>
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <div class="adora-header-overlay__drawer-utilities">
      {%- if section.settings.show_search -%}<a class="adora-header-overlay__drawer-utility" href="{{ routes.search_url }}">{{ section.settings.search_label | default: 'Search' | escape }}</a>{%- endif -%}
      {%- if section.settings.show_account and shop.customer_accounts_enabled -%}<a class="adora-header-overlay__drawer-utility" href="{{ routes.account_url }}">{{ section.settings.account_label | default: 'Account' | escape }}</a>{%- endif -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'utility_link' and block.settings.show_mobile and block.settings.label != blank -%}
          <a class="adora-header-overlay__drawer-utility" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </aside>
</header>

{% schema %}
{
  "name": "ADORA Header Overlay",
  "tag": "section",
  "class": "adora-header-overlay-section",
  "max_blocks": 12,
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "checkbox", "id": "enable_header", "label": "Enable header", "default": true },
    { "type": "link_list", "id": "menu", "label": "Menu" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "ADORA" },
    { "type": "range", "id": "logo_width_desktop", "label": "Logo width desktop", "min": 70, "max": 300, "step": 5, "unit": "px", "default": 150 },
    { "type": "range", "id": "logo_width_mobile", "label": "Logo width mobile", "min": 60, "max": 180, "step": 5, "unit": "px", "default": 100 },
    { "type": "header", "content": "Behavior" },
    { "type": "checkbox", "id": "enable_transparent_on_homepage", "label": "Enable transparent on homepage", "default": true },
    { "type": "checkbox", "id": "enable_hide_on_scroll_down", "label": "Hide on scroll down", "default": true },
    { "type": "checkbox", "id": "enable_show_on_scroll_up", "label": "Show on scroll up", "default": true },
    { "type": "checkbox", "id": "enable_solid_after_scroll", "label": "Use solid background after scroll", "default": true },
    { "type": "range", "id": "scroll_threshold", "label": "Scroll threshold", "min": 20, "max": 300, "step": 10, "unit": "px", "default": 80 },
    { "type": "checkbox", "id": "enable_blur_on_scroll", "label": "Enable blur on scroll", "default": true },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "transparent_text_color", "label": "Transparent text color", "default": "#FFFFFF" },
    { "type": "color", "id": "solid_bg_color", "label": "Solid background color", "default": "#F7F1EA" },
    { "type": "color", "id": "solid_text_color", "label": "Solid text color", "default": "#2B211D" },
    { "type": "color", "id": "drawer_bg_color", "label": "Drawer background color", "default": "#F7F1EA" },
    { "type": "color", "id": "drawer_text_color", "label": "Drawer text color", "default": "#2B211D" },
    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "header_height_desktop", "label": "Header height desktop", "min": 56, "max": 120, "step": 2, "unit": "px", "default": 76 },
    { "type": "range", "id": "header_height_mobile", "label": "Header height mobile", "min": 52, "max": 92, "step": 2, "unit": "px", "default": 64 },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
    { "type": "text", "id": "search_label", "label": "Search label", "default": "Search" },
    { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
    { "type": "text", "id": "account_label", "label": "Account label", "default": "Account" },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart", "default": true },
    { "type": "text", "id": "cart_label", "label": "Cart label", "default": "Cart" },
    { "type": "checkbox", "id": "show_cart_count", "label": "Show cart count", "default": true }
  ],
  "blocks": [
    {
      "type": "utility_link",
      "name": "Utility link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Ritual" },
        { "type": "url", "id": "url", "label": "URL" },
        { "type": "checkbox", "id": "show_desktop", "label": "Show desktop", "default": true },
        { "type": "checkbox", "id": "show_mobile", "label": "Show mobile", "default": true }
      ]
    }
  ],
  "presets": [
    { "name": "ADORA Header Overlay" }
  ]
}
{% endschema %}
