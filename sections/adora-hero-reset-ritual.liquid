{%- liquid
  assign hero_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image
  assign image_alt = section.settings.image_alt | default: hero_image.alt | default: section.settings.headline | escape
  assign desktop_video_url = section.settings.desktop_video_url
  assign mobile_video_url = section.settings.mobile_video_url | default: desktop_video_url
  assign use_video = false
  assign reveal_attr = ''

  if section.settings.media_type == 'video' and desktop_video_url != blank
    assign use_video = true
  endif

  if section.settings.enable_reveal
    assign reveal_attr = 'data-adora-reveal'
  endif
-%}

<section
  class="adora-hero-reset adora-hero-reset--{{ section.settings.hero_height }} adora-hero-reset--content-{{ section.settings.content_position_desktop }} adora-hero-reset--content-mobile-{{ section.settings.content_position_mobile }} adora-hero-reset--badges-desktop-{{ section.settings.trust_badge_layout_desktop }} adora-hero-reset--badges-mobile-{{ section.settings.trust_badge_layout_mobile }}{% if section.settings.show_glow_veil %} adora-hero-reset--glow{% endif %}"
  style="
    --adora-hero-reset-bg: {{ section.settings.background_color }};
    --adora-hero-reset-text: {{ section.settings.text_color }};
    --adora-hero-reset-accent: {{ section.settings.accent_color }};
    --adora-hero-reset-padding-desktop: {{ section.settings.padding_desktop }}px;
    --adora-hero-reset-padding-mobile: {{ section.settings.padding_mobile }}px;
    --adora-hero-reset-frame-radius: {{ section.settings.frame_radius }}px;
    --adora-hero-reset-overlay-color: {{ section.settings.overlay_color }};
    --adora-hero-reset-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --adora-hero-trust-icon-size-default: {{ section.settings.trust_badge_icon_size }}px;
  "
>
  <div class="adora-hero-reset__frame" {{ reveal_attr }}>
    <div class="adora-hero-reset__media">
      {%- if use_video -%}
        <video
          class="adora-hero-reset__video"
          {% if section.settings.video_autoplay %}autoplay{% endif %}
          {% if section.settings.video_loop %}loop{% endif %}
          {% if section.settings.video_muted %}muted{% endif %}
          {% if section.settings.video_playsinline %}playsinline{% endif %}
          {% if section.settings.show_video_controls %}controls{% endif %}
          {% if section.settings.video_poster_image != blank %}poster="{{ section.settings.video_poster_image | image_url: width: 1800 }}"{% endif %}
          preload="metadata"
        >
          {%- if mobile_video_url != blank -%}<source src="{{ mobile_video_url }}" media="(max-width: 749px)">{%- endif -%}
          <source src="{{ desktop_video_url }}">
        </video>
      {%- elsif hero_image != blank -%}
        <picture>
          {%- if mobile_image != blank -%}
            <source media="(max-width: 749px)" srcset="{{ mobile_image | image_url: width: 640 }} 640w, {{ mobile_image | image_url: width: 960 }} 960w, {{ mobile_image | image_url: width: 1200 }} 1200w" sizes="100vw">
          {%- endif -%}
          <source media="(min-width: 750px)" srcset="{{ hero_image | image_url: width: 1200 }} 1200w, {{ hero_image | image_url: width: 1600 }} 1600w, {{ hero_image | image_url: width: 2200 }} 2200w, {{ hero_image | image_url: width: 2800 }} 2800w" sizes="100vw">
          {{ hero_image | image_url: width: 2200 | image_tag: class: 'adora-hero-reset__image', alt: image_alt, loading: 'eager', fetchpriority: 'high', widths: '640, 960, 1200, 1600, 2200, 2800', sizes: '100vw' }}
        </picture>
      {%- else -%}
        <div class="adora-hero-reset__placeholder" aria-hidden="true"><span>ADORA</span></div>
      {%- endif -%}
      <div class="adora-hero-reset__overlay" aria-hidden="true"></div>
    </div>

    <div class="adora-hero-reset__content" {{ reveal_attr }}>
      {%- if section.settings.eyebrow != blank -%}<p class="adora-hero-reset__eyebrow">{{ section.settings.eyebrow | escape }}</p>{%- endif -%}
      {%- if section.settings.headline != blank -%}<h1 class="adora-hero-reset__heading">{{ section.settings.headline | escape }}</h1>{%- endif -%}
      {%- if section.settings.subheadline != blank -%}<div class="adora-hero-reset__subheading">{{ section.settings.subheadline }}</div>{%- endif -%}
      <div class="adora-hero-reset__actions">
        {%- if section.settings.primary_button_label != blank -%}<a class="adora-hero-reset__button adora-hero-reset__button--primary" href="{{ section.settings.primary_button_link | default: '#' }}">{{ section.settings.primary_button_label | escape }}</a>{%- endif -%}
        {%- if section.settings.secondary_button_label != blank -%}<a class="adora-hero-reset__button adora-hero-reset__button--secondary" href="{{ section.settings.secondary_button_link | default: '#' }}">{{ section.settings.secondary_button_label | escape }}</a>{%- endif -%}
      </div>
      {%- if section.settings.show_trust_badges and section.blocks.size > 0 -%}
        <ul class="adora-hero-reset__badges" aria-label="ADORA Ritual Vorteile">
          {%- for block in section.blocks -%}
            {%- if block.settings.badge_text != blank or block.settings.badge_icon != blank -%}
              <li class="adora-hero-reset__badge-item" {{ block.shopify_attributes }}>
                {% render 'adora-trust-badge', badge_text: block.settings.badge_text, badge_icon: block.settings.badge_icon, badge_icon_alt: block.settings.badge_icon_alt, badge_icon_size: block.settings.badge_icon_size, badge_link: block.settings.badge_link, show_badge_text: block.settings.show_badge_text, show_badge_icon: block.settings.show_badge_icon %}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .adora-hero-reset {
    position: relative;
    padding: var(--adora-hero-reset-padding-mobile);
    background: var(--adora-hero-reset-bg);
    color: var(--adora-hero-reset-text);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__frame {
    position: relative;
    min-height: {% if section.settings.hero_height == 'compact' %}620px{% elsif section.settings.hero_height == 'full' %}calc(100svh - (var(--adora-hero-reset-padding-mobile) * 2)){% else %}calc(92svh - (var(--adora-hero-reset-padding-mobile) * 2)){% endif %};
    overflow: hidden;
    border-radius: var(--adora-hero-reset-frame-radius);
    background: var(--adora-bg-soft);
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset--glow .adora-hero-reset__frame::before {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 2;
    background: radial-gradient(circle at 24% 86%, rgba(247, 241, 234, 0.32), transparent 38%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__media,
  #shopify-section-{{ section.id }} .adora-hero-reset__media picture,
  #shopify-section-{{ section.id }} .adora-hero-reset__image,
  #shopify-section-{{ section.id }} .adora-hero-reset__video,
  #shopify-section-{{ section.id }} .adora-hero-reset__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__image,
  #shopify-section-{{ section.id }} .adora-hero-reset__video {
    display: block;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__overlay {
    position: absolute;
    inset: 0;
    background: var(--adora-hero-reset-overlay-color);
    opacity: var(--adora-hero-reset-overlay-opacity);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__placeholder {
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, #efe3d7, #e8cfc5);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__placeholder span {
    color: rgba(43, 33, 29, 0.18);
    font-family: var(--font-heading-family, inherit);
    font-size: clamp(4rem, 18vw, 14rem);
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__content {
    position: absolute;
    right: clamp(22px, 4vw, 56px);
    bottom: clamp(24px, 5vw, 74px);
    left: clamp(22px, 4vw, 56px);
    z-index: 3;
    max-width: min(720px, 92%);
    color: var(--adora-hero-reset-text);
    text-align: {{ section.settings.text_alignment }};
  }

  #shopify-section-{{ section.id }} .adora-hero-reset--content-top .adora-hero-reset__content { top: clamp(110px, 16vw, 170px); bottom: auto; }
  #shopify-section-{{ section.id }} .adora-hero-reset--content-center .adora-hero-reset__content { top: 50%; bottom: auto; transform: translateY(-50%); }
  #shopify-section-{{ section.id }} .adora-hero-reset--content-bottom .adora-hero-reset__content { bottom: clamp(24px, 5vw, 74px); }

  #shopify-section-{{ section.id }} .adora-hero-reset__eyebrow {
    margin: 0 0 12px;
    color: var(--adora-hero-reset-accent);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__heading {
    max-width: 13ch;
    margin: 0;
    color: currentColor;
    font-family: var(--font-heading-family, inherit);
    font-size: clamp(2.7rem, 8vw, 5.9rem);
    font-weight: 500;
    letter-spacing: -0.03em;
    line-height: 0.95;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__subheading {
    max-width: 620px;
    margin-top: 18px;
    font-size: clamp(0.98rem, 1.8vw, 1.18rem);
    line-height: 1.55;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__subheading p { margin: 0; }

  #shopify-section-{{ section.id }} .adora-hero-reset__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-top: 24px;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 10px 28px;
    border: 1px solid currentColor;
    border-radius: 999px;
    color: currentColor;
    background: transparent;
    font-size: 0.86rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    line-height: 1;
    text-decoration: none;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__button--primary {
    color: var(--adora-hero-reset-bg);
    background: var(--adora-hero-reset-text);
    border-color: var(--adora-hero-reset-text);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    padding: 0;
    margin: 24px 0 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .adora-hero-trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    min-height: 36px;
    padding: 8px 13px;
    color: currentColor;
    background: rgba(255, 255, 255, 0.16);
    border: 1px solid rgba(255, 255, 255, 0.32);
    border-radius: 999px;
    backdrop-filter: blur(10px);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.04em;
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
  }

  #shopify-section-{{ section.id }} .adora-hero-trust-badge__icon {
    width: var(--adora-hero-trust-icon-size, var(--adora-hero-trust-icon-size-default));
    height: var(--adora-hero-trust-icon-size, var(--adora-hero-trust-icon-size-default));
    object-fit: contain;
  }

  @media screen and (max-width: 749px) {
    #shopify-section-{{ section.id }} .adora-hero-reset--content-mobile-top .adora-hero-reset__content { top: 98px; bottom: auto; transform: none; }
    #shopify-section-{{ section.id }} .adora-hero-reset--content-mobile-center .adora-hero-reset__content { top: 50%; bottom: auto; transform: translateY(-50%); }
    #shopify-section-{{ section.id }} .adora-hero-reset--content-mobile-bottom .adora-hero-reset__content { top: auto; bottom: 26px; transform: none; }
    #shopify-section-{{ section.id }} .adora-hero-reset__actions { display: grid; }
    #shopify-section-{{ section.id }} .adora-hero-reset__button { width: 100%; }
    #shopify-section-{{ section.id }} .adora-hero-reset--badges-mobile-scroll .adora-hero-reset__badges { flex-wrap: nowrap; overflow-x: auto; padding-bottom: 4px; }
    #shopify-section-{{ section.id }} .adora-hero-reset--badges-mobile-stacked .adora-hero-reset__badges { display: grid; }
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .adora-hero-reset {
      padding: var(--adora-hero-reset-padding-desktop);
    }

    #shopify-section-{{ section.id }} .adora-hero-reset__frame {
      min-height: {% if section.settings.hero_height == 'compact' %}720px{% elsif section.settings.hero_height == 'full' %}calc(100svh - (var(--adora-hero-reset-padding-desktop) * 2)){% else %}calc(92svh - (var(--adora-hero-reset-padding-desktop) * 2)){% endif %};
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--badges-desktop-grid .adora-hero-reset__badges { display: grid; grid-template-columns: repeat(2, max-content); }
    #shopify-section-{{ section.id }} .adora-hero-reset--badges-desktop-floating .adora-hero-reset__badges { position: absolute; right: 0; bottom: 0; max-width: 420px; }
  }
{% endstyle %}

{% schema %}
{
  "name": "ADORA Reset Ritual Hero",
  "tag": "section",
  "class": "adora-hero-reset-section",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow text", "default": "ADORA GLASS SKIN RITUAL" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Dein 3-Step Reset für sichtbar mehr Glow." },
    { "type": "richtext", "id": "subheadline", "label": "Subheadline", "default": "<p>Ein ruhiges Skincare-Ritual aus Reinigung, Feuchtigkeit und nährendem Finish — entwickelt für Haut, die weich, gepflegt und natürlich strahlend wirken soll.</p>" },
    { "type": "text", "id": "primary_button_label", "label": "Primary button label", "default": "Ritual entdecken" },
    { "type": "url", "id": "primary_button_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_button_label", "label": "Secondary button label", "default": "Die 3 Schritte ansehen" },
    { "type": "url", "id": "secondary_button_link", "label": "Secondary button link" },
    { "type": "header", "content": "Media" },
    { "type": "select", "id": "media_type", "label": "Hero media type", "options": [{ "value": "image", "label": "Image" }, { "value": "video", "label": "Video" }], "default": "image" },
    { "type": "image_picker", "id": "desktop_image", "label": "Desktop hero image" },
    { "type": "image_picker", "id": "mobile_image", "label": "Mobile hero image" },
    { "type": "text", "id": "image_alt", "label": "Image alt text", "default": "ADORA Glass Skin Ritual" },
    { "type": "url", "id": "desktop_video_url", "label": "Desktop video URL" },
    { "type": "url", "id": "mobile_video_url", "label": "Mobile video URL" },
    { "type": "image_picker", "id": "video_poster_image", "label": "Video poster image" },
    { "type": "checkbox", "id": "video_autoplay", "label": "Video autoplay", "default": true },
    { "type": "checkbox", "id": "video_loop", "label": "Video loop", "default": true },
    { "type": "checkbox", "id": "video_muted", "label": "Video muted", "default": true },
    { "type": "checkbox", "id": "video_playsinline", "label": "Video plays inline", "default": true },
    { "type": "checkbox", "id": "show_video_controls", "label": "Show video controls", "default": false },
    { "type": "header", "content": "Overlay" },
    { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
    { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity", "min": 0, "max": 70, "step": 5, "unit": "%", "default": 30 },
    { "type": "select", "id": "content_position_desktop", "label": "Content position desktop", "options": [{ "value": "top", "label": "Top" }, { "value": "center", "label": "Center" }, { "value": "bottom", "label": "Bottom" }], "default": "bottom" },
    { "type": "select", "id": "content_position_mobile", "label": "Content position mobile", "options": [{ "value": "top", "label": "Top" }, { "value": "center", "label": "Center" }, { "value": "bottom", "label": "Bottom" }], "default": "bottom" },
    { "type": "header", "content": "Style" },
    { "type": "color", "id": "background_color", "label": "Page background color", "default": "#F7F1EA" },
    { "type": "color", "id": "text_color", "label": "Hero text color", "default": "#FFFFFF" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#F7F1EA" },
    { "type": "range", "id": "padding_desktop", "label": "Outer spacing desktop", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "padding_mobile", "label": "Outer spacing mobile", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "frame_radius", "label": "Hero frame radius", "min": 0, "max": 40, "step": 2, "unit": "px", "default": 18 },
    { "type": "select", "id": "text_alignment", "label": "Text alignment", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" },
    { "type": "select", "id": "hero_height", "label": "Hero height", "options": [{ "value": "compact", "label": "Compact" }, { "value": "standard", "label": "Standard" }, { "value": "full", "label": "Full" }], "default": "standard" },
    { "type": "checkbox", "id": "show_trust_badges", "label": "Show trust badges", "default": true },
    { "type": "select", "id": "trust_badge_layout_desktop", "label": "Trust badge layout desktop", "options": [{ "value": "row", "label": "Row" }, { "value": "grid", "label": "Grid" }, { "value": "floating", "label": "Floating" }], "default": "row" },
    { "type": "select", "id": "trust_badge_layout_mobile", "label": "Trust badge layout mobile", "options": [{ "value": "wrap", "label": "Wrap" }, { "value": "scroll", "label": "Scroll" }, { "value": "stacked", "label": "Stacked" }], "default": "wrap" },
    { "type": "range", "id": "trust_badge_icon_size", "label": "Trust badge icon size fallback", "min": 12, "max": 48, "step": 2, "unit": "px", "default": 22 },
    { "type": "checkbox", "id": "show_glow_veil", "label": "Show glow veil", "default": true },
    { "type": "checkbox", "id": "enable_reveal", "label": "Enable soft reveal animation", "default": true }
  ],
  "blocks": [
    { "type": "trust_badge", "name": "Trust badge", "settings": [
      { "type": "text", "id": "badge_text", "label": "Badge text", "default": "3-Step Routine" },
      { "type": "image_picker", "id": "badge_icon", "label": "Badge icon" },
      { "type": "text", "id": "badge_icon_alt", "label": "Badge icon alt text" },
      { "type": "range", "id": "badge_icon_size", "label": "Badge icon size", "min": 12, "max": 48, "step": 2, "unit": "px", "default": 22 },
      { "type": "url", "id": "badge_link", "label": "Badge link" },
      { "type": "checkbox", "id": "show_badge_text", "label": "Show badge text", "default": true },
      { "type": "checkbox", "id": "show_badge_icon", "label": "Show badge icon", "default": true }
    ] }
  ],
  "presets": [{ "name": "ADORA Reset Ritual Hero", "blocks": [
    { "type": "trust_badge", "settings": { "badge_text": "3-Step Routine" } },
    { "type": "trust_badge", "settings": { "badge_text": "Vegan" } },
    { "type": "trust_badge", "settings": { "badge_text": "Made in Europe" } },
    { "type": "trust_badge", "settings": { "badge_text": "Premium Ritual Box" } }
  ] }]
}
{% endschema %}
