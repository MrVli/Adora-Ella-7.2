{%- liquid
  assign hero_image = section.settings.desktop_image
  assign mobile_image = section.settings.mobile_image
  assign image_alt = section.settings.image_alt | default: hero_image.alt | default: section.settings.headline | escape
  assign reveal_attr = ''

  if section.settings.enable_reveal
    assign reveal_attr = 'data-adora-reveal'
  endif
-%}

<section
  class="adora-section adora-hero-reset adora-hero-reset--{{ section.settings.hero_height }} adora-hero-reset--image-{{ section.settings.image_position }} adora-hero-reset--text-{{ section.settings.text_alignment }}{% if section.settings.show_glow_veil %} adora-hero-reset--glow{% endif %}"
  style="
    --adora-hero-reset-bg: {{ section.settings.background_color }};
    --adora-hero-reset-text: {{ section.settings.text_color }};
    --adora-hero-reset-accent: {{ section.settings.accent_color }};
    --adora-hero-reset-padding-desktop: {{ section.settings.padding_desktop }}px;
    --adora-hero-reset-padding-mobile: {{ section.settings.padding_mobile }}px;
  "
>
  <div class="adora-container adora-hero-reset__container">
    <div class="adora-hero-reset__media" {{ reveal_attr }}>
      <div class="adora-image-frame adora-hero-reset__image-frame">
        {%- if hero_image != blank -%}
          <picture>
            {%- if mobile_image != blank -%}
              <source
                media="(max-width: 749px)"
                srcset="
                  {{ mobile_image | image_url: width: 480 }} 480w,
                  {{ mobile_image | image_url: width: 720 }} 720w,
                  {{ mobile_image | image_url: width: 960 }} 960w
                "
                sizes="100vw"
              >
            {%- endif -%}
            <source
              media="(min-width: 750px)"
              srcset="
                {{ hero_image | image_url: width: 720 }} 720w,
                {{ hero_image | image_url: width: 960 }} 960w,
                {{ hero_image | image_url: width: 1280 }} 1280w,
                {{ hero_image | image_url: width: 1600 }} 1600w
              "
              sizes="(min-width: 1440px) 680px, 48vw"
            >
            {{ hero_image | image_url: width: 1400 | image_tag:
              class: 'adora-hero-reset__image',
              alt: image_alt,
              loading: 'eager',
              fetchpriority: 'high',
              widths: '480, 720, 960, 1280, 1600',
              sizes: '(min-width: 1440px) 680px, (min-width: 750px) 48vw, 100vw'
            }}
          </picture>
        {%- else -%}
          <div class="adora-hero-reset__placeholder" aria-hidden="true">
            <span class="adora-hero-reset__placeholder-mark">ADORA</span>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="adora-hero-reset__content" {{ reveal_attr }}>
      {%- if section.settings.eyebrow != blank -%}
        <p class="adora-eyebrow adora-hero-reset__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}

      {%- if section.settings.headline != blank -%}
        <h1 class="adora-heading adora-hero-reset__heading">{{ section.settings.headline | escape }}</h1>
      {%- endif -%}

      {%- if section.settings.subheadline != blank -%}
        <div class="adora-richtext adora-subheading adora-hero-reset__subheading">
          {{ section.settings.subheadline }}
        </div>
      {%- endif -%}

      <div class="adora-hero-reset__actions">
        {%- if section.settings.primary_button_label != blank -%}
          {%- if section.settings.primary_button_link != blank -%}
            <a class="adora-button adora-button--primary adora-hero-reset__button" href="{{ section.settings.primary_button_link }}">
              {{ section.settings.primary_button_label | escape }}
            </a>
          {%- else -%}
            <span class="adora-button adora-button--primary adora-hero-reset__button" aria-disabled="true">
              {{ section.settings.primary_button_label | escape }}
            </span>
          {%- endif -%}
        {%- endif -%}

        {%- if section.settings.secondary_button_label != blank -%}
          {%- if section.settings.secondary_button_link != blank -%}
            <a class="adora-button adora-button--secondary adora-hero-reset__button" href="{{ section.settings.secondary_button_link }}">
              {{ section.settings.secondary_button_label | escape }}
            </a>
          {%- else -%}
            <span class="adora-button adora-button--secondary adora-hero-reset__button" aria-disabled="true">
              {{ section.settings.secondary_button_label | escape }}
            </span>
          {%- endif -%}
        {%- endif -%}
      </div>

      {%- if section.settings.show_trust_badges and section.blocks.size > 0 -%}
        <ul class="adora-hero-reset__badges" aria-label="ADORA Ritual Vorteile">
          {%- for block in section.blocks -%}
            {%- if block.settings.text != blank -%}
              <li class="adora-badge adora-hero-reset__badge" {{ block.shopify_attributes }}>
                {{ block.settings.text | escape }}
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  #shopify-section-{{ section.id }} .adora-hero-reset {
    min-height: auto;
    padding: var(--adora-hero-reset-padding-mobile) 0;
    color: var(--adora-hero-reset-text);
    background:
      radial-gradient(circle at 18% 12%, rgba(232, 207, 197, 0.42), transparent 34%),
      var(--adora-hero-reset-bg);
    isolation: isolate;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset--glow::before {
    content: '';
    position: absolute;
    inset: 8% auto auto 50%;
    z-index: -1;
    width: min(58vw, 620px);
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(201, 168, 141, 0.28), transparent 68%);
    filter: blur(8px);
    transform: translateX(-50%);
    pointer-events: none;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__container {
    display: grid;
    gap: clamp(28px, 7vw, 78px);
    align-items: center;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__media {
    order: 1;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__content {
    order: 2;
    text-align: {{ section.settings.text_alignment }};
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__content[data-adora-reveal],
  #shopify-section-{{ section.id }} .adora-hero-reset__media[data-adora-reveal] {
    will-change: opacity, transform;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__eyebrow {
    color: var(--adora-hero-reset-accent);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__heading {
    max-width: 11ch;
    color: var(--adora-hero-reset-text);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset--text-center .adora-hero-reset__heading,
  #shopify-section-{{ section.id }} .adora-hero-reset--text-center .adora-hero-reset__subheading {
    margin-inline: auto;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__subheading {
    color: rgba(43, 33, 29, 0.72);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__actions {
    display: grid;
    gap: 12px;
    margin-top: clamp(24px, 5vw, 38px);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__button {
    width: 100%;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: {% if section.settings.text_alignment == 'center' %}center{% else %}flex-start{% endif %};
    padding: 0;
    margin: clamp(24px, 5vw, 36px) 0 0;
    list-style: none;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__badge {
    background: rgba(255, 255, 255, 0.56);
    backdrop-filter: blur(12px);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__image-frame {
    min-height: clamp(360px, 72vw, 620px);
    border: 1px solid rgba(43, 33, 29, 0.08);
    box-shadow: var(--adora-shadow-soft);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__image {
    min-height: inherit;
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__placeholder {
    display: grid;
    min-height: inherit;
    place-items: center;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.48), rgba(232, 207, 197, 0.62)),
      var(--adora-bg-soft);
  }

  #shopify-section-{{ section.id }} .adora-hero-reset__placeholder-mark {
    color: rgba(43, 33, 29, 0.2);
    font-family: var(--font-heading-family, inherit);
    font-size: clamp(2.2rem, 12vw, 7rem);
    letter-spacing: 0.14em;
  }

  @media screen and (min-width: 750px) {
    #shopify-section-{{ section.id }} .adora-hero-reset {
      display: flex;
      min-height: {% if section.settings.hero_height == 'compact' %}70vh{% elsif section.settings.hero_height == 'full' %}100svh{% else %}80vh{% endif %};
      padding: var(--adora-hero-reset-padding-desktop) 0;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset__container {
      grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--image-left .adora-hero-reset__container {
      grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--image-left .adora-hero-reset__media {
      order: 1;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--image-left .adora-hero-reset__content {
      order: 2;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--image-right .adora-hero-reset__content {
      order: 1;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset--image-right .adora-hero-reset__media {
      order: 2;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset__actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset__button {
      width: auto;
    }

    #shopify-section-{{ section.id }} .adora-hero-reset__image-frame {
      min-height: {% if section.settings.hero_height == 'compact' %}520px{% elsif section.settings.hero_height == 'full' %}min(820px, 82vh){% else %}min(720px, 74vh){% endif %};
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #shopify-section-{{ section.id }} .adora-hero-reset__content[data-adora-reveal],
    #shopify-section-{{ section.id }} .adora-hero-reset__media[data-adora-reveal] {
      will-change: auto;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "ADORA Reset Ritual Hero",
  "tag": "section",
  "class": "adora-hero-reset-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "ADORA GLASS SKIN RITUAL"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Dein 3-Step Reset für sichtbar mehr Glow."
    },
    {
      "type": "richtext",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "<p>Ein ruhiges Skincare-Ritual aus Reinigung, Feuchtigkeit und nährendem Finish — entwickelt für Haut, die weich, gepflegt und natürlich strahlend wirken soll.</p>"
    },
    {
      "type": "text",
      "id": "primary_button_label",
      "label": "Primary button label",
      "default": "Ritual entdecken"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "secondary_button_label",
      "label": "Secondary button label",
      "default": "Die 3 Schritte ansehen"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary button link"
    },
    {
      "type": "image_picker",
      "id": "desktop_image",
      "label": "Desktop hero image"
    },
    {
      "type": "image_picker",
      "id": "mobile_image",
      "label": "Mobile hero image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "default": "ADORA Glass Skin Ritual"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#F7F1EA"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#2B211D"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#C9A88D"
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "label": "Section padding desktop",
      "min": 48,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Section padding mobile",
      "min": 28,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        {
          "value": "right",
          "label": "Right"
        },
        {
          "value": "left",
          "label": "Left"
        }
      ],
      "default": "right"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "hero_height",
      "label": "Hero height",
      "options": [
        {
          "value": "compact",
          "label": "Compact"
        },
        {
          "value": "standard",
          "label": "Standard"
        },
        {
          "value": "full",
          "label": "Full"
        }
      ],
      "default": "standard"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badges",
      "label": "Show trust badges",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_glow_veil",
      "label": "Show glow veil",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_reveal",
      "label": "Enable soft reveal animation",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "3-Step Routine"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "ADORA Reset Ritual Hero",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": {
            "text": "3-Step Routine"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Vegan"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Made in Europe"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "text": "Premium Ritual Box"
          }
        }
      ]
    }
  ]
}
{% endschema %}
