{%- liquid
  assign drawer_id = 'AdoraHeaderDrawer-' | append: section.id
  assign mega_id = 'AdoraMegaMenu-' | append: section.id
  assign logo_alt = section.settings.logo_image.alt | default: section.settings.logo_text | escape
  assign mega_categories = section.blocks | where: 'type', 'mega_category'
  assign mega_trigger = section.settings.mega_menu_trigger_label | default: 'Shop' | downcase
-%}

<header
  class="adora-header adora-header--visible adora-header--solid adora-header--nav-{{ section.settings.desktop_nav_position }}{% if section.settings.enable_blur_on_scroll %} adora-header--blur{% endif %}{% if section.settings.enable_bottom_border %} adora-header--border{% endif %}{% if section.settings.enable_soft_shadow %} adora-header--shadow{% endif %}{% if section.settings.enable_hero_frame_mode %} adora-header--hero-frame{% endif %}"
  data-adora-header
  data-homepage="{% if request.page_type == 'index' %}true{% else %}false{% endif %}"
  data-transparent-homepage="{{ section.settings.enable_transparent_on_homepage }}"
  data-hide-on-scroll-down="{{ section.settings.enable_hide_on_scroll_down }}"
  data-show-on-scroll-up="{{ section.settings.enable_show_on_scroll_up }}"
  data-solid-after-scroll="{{ section.settings.enable_solid_after_scroll }}"
  data-scroll-threshold="{{ section.settings.scroll_threshold }}"
  data-sticky-mode="{{ section.settings.sticky_mode }}"
  data-drawer-id="{{ drawer_id }}"
  data-mega-id="{{ mega_id }}"
  style="
    --adora-header-height-desktop: {{ section.settings.header_height_desktop }}px;
    --adora-header-height-mobile: {{ section.settings.header_height_mobile }}px;
    --adora-header-logo-width-desktop: {{ section.settings.logo_width_desktop }}px;
    --adora-header-logo-width-mobile: {{ section.settings.logo_width_mobile }}px;
    --adora-header-transparent-text: {{ section.settings.transparent_text_color }};
    --adora-header-solid-bg: {{ section.settings.solid_bg_color }};
    --adora-header-solid-text: {{ section.settings.solid_text_color }};
    --adora-header-border: {{ section.settings.border_color }};
    --adora-header-drawer-bg: {{ section.settings.drawer_bg_color }};
    --adora-header-drawer-text: {{ section.settings.drawer_text_color }};
    --adora-header-accent: {{ section.settings.accent_color }};
    --adora-header-nav-size: {{ section.settings.nav_font_size }}px;
    --adora-header-nav-spacing: {{ section.settings.nav_letter_spacing | divided_by: 10.0 }}px;
    --adora-header-announcement-bg: {{ section.settings.announcement_bg_color }};
    --adora-header-announcement-text: {{ section.settings.announcement_text_color }};
    --adora-header-frame-inset-desktop: {{ section.settings.hero_frame_inset_desktop }}px;
    --adora-header-frame-inset-mobile: {{ section.settings.hero_frame_inset_mobile }}px;
    --adora-header-frame-radius: {{ section.settings.hero_frame_radius }}px;
  "
  {% unless section.settings.enable_header %}hidden{% endunless %}
>
  {%- if section.settings.show_announcement -%}
    <div class="adora-header__announcement">
      {%- if section.settings.announcement_text != blank -%}<div class="adora-header__announcement-text">{{ section.settings.announcement_text }}</div>{%- endif -%}
      {%- if section.settings.announcement_link_label != blank -%}<a class="adora-header__announcement-link" href="{{ section.settings.announcement_link_url | default: '#' }}">{{ section.settings.announcement_link_label | escape }}</a>{%- endif -%}
    </div>
  {%- endif -%}

  <div class="adora-header__inner">
    <div class="adora-header__mobile-left">
      <button class="adora-header__burger" type="button" aria-label="Menü öffnen" aria-controls="{{ drawer_id }}" aria-expanded="false" data-adora-header-burger>
        <span class="adora-header__burger-icon" aria-hidden="true"><span></span></span>
      </button>
    </div>

    <nav class="adora-header__nav" aria-label="Hauptnavigation">
      {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
        <ul class="adora-header__nav-list">
          {%- for link in section.settings.menu.links -%}
            {%- liquid
              assign link_title_downcase = link.title | downcase
              assign is_mega_trigger = false
              if section.settings.enable_mega_menu and mega_categories.size > 0 and link_title_downcase == mega_trigger
                assign is_mega_trigger = true
              endif
            -%}
            <li>
              <a
                class="adora-header__nav-link{% if is_mega_trigger %} adora-header__nav-link--mega{% endif %}"
                href="{{ link.url }}"
                {% if is_mega_trigger %}aria-controls="{{ mega_id }}" aria-expanded="false" data-adora-mega-trigger{% endif %}
              >{{ link.title | escape }}</a>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    <a class="adora-header__logo" href="{{ routes.root_url }}" aria-label="{{ shop.name | escape }}">
      {%- if section.settings.logo_image != blank -%}
        {{ section.settings.logo_image | image_url: width: 420 | image_tag: class: 'adora-header__logo-image', alt: logo_alt, loading: 'eager', widths: '120, 180, 240, 320, 420', sizes: '(min-width: 990px) var(--adora-header-logo-width-desktop), var(--adora-header-logo-width-mobile)' }}
      {%- else -%}
        <span class="adora-header__logo-text">{{ section.settings.logo_text | default: 'ADORA' | escape }}</span>
      {%- endif -%}
    </a>

    <div class="adora-header__utilities" aria-label="Header Links">
      <ul class="adora-header__utility-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'utility_link' and block.settings.show_desktop and block.settings.label != blank -%}<li {{ block.shopify_attributes }}><a class="adora-header__utility-link" href="{{ block.settings.url | default: '#' }}">{{ block.settings.label | escape }}</a></li>{%- endif -%}
        {%- endfor -%}
        {%- if section.settings.show_search -%}<li><a class="adora-header__utility-link" href="{{ routes.search_url }}">Search</a></li>{%- endif -%}
        {%- if section.settings.show_account and shop.customer_accounts_enabled -%}<li><a class="adora-header__utility-link" href="{{ routes.account_url }}">Account</a></li>{%- endif -%}
        {%- if section.settings.show_cart -%}<li><a class="adora-header__utility-link adora-header__cart-link" href="{{ routes.cart_url }}">Cart {%- if section.settings.show_cart_count -%}<span class="adora-header__cart-count">({{ cart.item_count }})</span>{%- endif -%}</a></li>{%- endif -%}
      </ul>
    </div>

    <div class="adora-header__mobile-cart">
      {%- if section.settings.show_cart -%}<a class="adora-header__cart-link" href="{{ routes.cart_url }}" aria-label="Warenkorb">Cart {%- if section.settings.show_cart_count -%}<span class="adora-header__cart-count">({{ cart.item_count }})</span>{%- endif -%}</a>{%- endif -%}
    </div>
  </div>

  {%- if section.settings.enable_mega_menu and mega_categories.size > 0 -%}
    <div id="{{ mega_id }}" class="adora-header__mega" aria-hidden="true" data-adora-mega-menu>
      <div class="adora-header__mega-shell">
        <div class="adora-header__mega-tabs" role="tablist" aria-label="Shop Kategorien">
          {%- for block in mega_categories -%}
            <button
              class="adora-header__mega-tab{% if forloop.first %} is-active{% endif %}"
              type="button"
              role="tab"
              aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
              aria-controls="AdoraMegaPanel-{{ section.id }}-{{ block.id }}"
              data-adora-mega-tab="{{ block.id }}"
              {{ block.shopify_attributes }}
            >{{ block.settings.title | default: block.settings.collection.title | default: 'Kategorie' | escape }}</button>
          {%- endfor -%}
        </div>

        {%- for block in mega_categories -%}
          {%- liquid
            assign category_title = block.settings.title | default: block.settings.collection.title | default: 'Kategorie'
            assign category_url = block.settings.category_link | default: block.settings.collection.url | default: '#'
            assign p1 = block.settings.product_1
            assign p2 = block.settings.product_2
            assign p3 = block.settings.product_3
            assign p4 = block.settings.product_4
          -%}
          <div id="AdoraMegaPanel-{{ section.id }}-{{ block.id }}" class="adora-header__mega-panel{% if forloop.first %} is-active{% endif %}" role="tabpanel" data-adora-mega-panel="{{ block.id }}">
            <div class="adora-header__mega-products">
              {%- if p1 != blank -%}{% render 'adora-mega-product-card', product: p1, badge: block.settings.product_1_badge %}{%- endif -%}
              {%- if p2 != blank -%}{% render 'adora-mega-product-card', product: p2, badge: block.settings.product_2_badge %}{%- endif -%}
              {%- if p3 != blank -%}{% render 'adora-mega-product-card', product: p3, badge: block.settings.product_3_badge %}{%- endif -%}
              {%- if p4 != blank -%}{% render 'adora-mega-product-card', product: p4, badge: block.settings.product_4_badge %}{%- endif -%}

              {%- if p1 == blank and p2 == blank and p3 == blank and p4 == blank and block.settings.collection != blank -%}
                {%- for product in block.settings.collection.products limit: 4 -%}
                  {% render 'adora-mega-product-card', product: product, badge: block.settings.fallback_badge %}
                {%- endfor -%}
              {%- endif -%}
            </div>
            <a class="adora-header__mega-cta" href="{{ category_url }}">{{ block.settings.cta_label | default: 'Kategorie ansehen' | escape }}</a>
          </div>
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}

  <div class="adora-header__drawer-overlay" aria-hidden="true" data-adora-header-overlay></div>
  <aside id="{{ drawer_id }}" class="adora-header__drawer adora-header__drawer--{{ section.settings.mobile_drawer_position }}" aria-hidden="true" aria-label="Mobile Navigation">
    <div class="adora-header__drawer-header">
      <a class="adora-header__drawer-logo" href="{{ routes.root_url }}">{{ section.settings.logo_text | default: 'ADORA' | escape }}</a>
      <button class="adora-header__drawer-close" type="button" aria-label="Menü schließen" data-adora-header-close>×</button>
    </div>
    {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}<nav class="adora-header__drawer-nav" aria-label="Mobile Hauptnavigation">{%- for link in section.settings.menu.links -%}<a class="adora-header__drawer-link" href="{{ link.url }}">{{ link.title | escape }}</a>{%- endfor -%}</nav>{%- endif -%}
    {%- if section.settings.enable_mega_menu and mega_categories.size > 0 -%}
      <div class="adora-header__drawer-mega" aria-label="Shop Kategorien">
        {%- for block in mega_categories -%}
          {%- liquid
            assign mobile_title = block.settings.title | default: block.settings.collection.title | default: 'Kategorie'
            assign mobile_url = block.settings.category_link | default: block.settings.collection.url | default: '#'
          -%}
          <a class="adora-header__drawer-mega-link" href="{{ mobile_url }}">{{ mobile_title | escape }}</a>
        {%- endfor -%}
      </div>
    {%- endif -%}
    <div class="adora-header__drawer-utilities">
      {%- if section.settings.show_mobile_search -%}<a class="adora-header__drawer-utility" href="{{ routes.search_url }}">Search</a>{%- endif -%}
      {%- if section.settings.show_mobile_account and shop.customer_accounts_enabled -%}<a class="adora-header__drawer-utility" href="{{ routes.account_url }}">Account</a>{%- endif -%}
      {%- for block in section.blocks -%}{%- if block.type == 'utility_link' and block.settings.show_mobile and block.settings.label != blank -%}<a class="adora-header__drawer-utility" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>{%- endif -%}{%- endfor -%}
    </div>
    {%- if section.settings.show_mobile_promo_text and section.settings.mobile_promo_text != blank -%}<div class="adora-header__drawer-promo">{{ section.settings.mobile_promo_text }}</div>{%- endif -%}
    <div class="adora-header__drawer-promos">{%- for block in section.blocks -%}{%- if block.type == 'drawer_promo_link' and block.settings.label != blank -%}<a class="adora-header__drawer-promo-link" href="{{ block.settings.url | default: '#' }}" {{ block.shopify_attributes }}>{{ block.settings.label | escape }}</a>{%- endif -%}{%- endfor -%}</div>
  </aside>
</header>

{% schema %}
{
  "name": "ADORA Header",
  "tag": "section",
  "class": "adora-header-section",
  "max_blocks": 18,
  "enabled_on": { "groups": ["header"] },
  "settings": [
    { "type": "checkbox", "id": "enable_header", "label": "Enable header", "default": true },
    { "type": "link_list", "id": "menu", "label": "Menu" },
    { "type": "image_picker", "id": "logo_image", "label": "Logo image" },
    { "type": "text", "id": "logo_text", "label": "Logo text", "default": "ADORA" },
    { "type": "range", "id": "logo_width_desktop", "label": "Logo width desktop", "min": 70, "max": 300, "step": 5, "unit": "px", "default": 150 },
    { "type": "range", "id": "logo_width_mobile", "label": "Logo width mobile", "min": 60, "max": 180, "step": 5, "unit": "px", "default": 100 },
    { "type": "header", "content": "Hero frame behavior" },
    { "type": "checkbox", "id": "enable_hero_frame_mode", "label": "Place header visually inside homepage hero", "default": true },
    { "type": "range", "id": "hero_frame_inset_desktop", "label": "Hero frame inset desktop", "min": 0, "max": 60, "step": 2, "unit": "px", "default": 24 },
    { "type": "range", "id": "hero_frame_inset_mobile", "label": "Hero frame inset mobile", "min": 0, "max": 32, "step": 2, "unit": "px", "default": 12 },
    { "type": "range", "id": "hero_frame_radius", "label": "Solid header radius", "min": 0, "max": 34, "step": 2, "unit": "px", "default": 18 },
    { "type": "header", "content": "Mega menu" },
    { "type": "checkbox", "id": "enable_mega_menu", "label": "Enable product mega menu", "default": true },
    { "type": "text", "id": "mega_menu_trigger_label", "label": "Menu item that opens mega menu", "default": "Shop" },
    { "type": "header", "content": "Announcement bar" },
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": false },
    { "type": "richtext", "id": "announcement_text", "label": "Announcement text", "default": "<p>Ein ruhiges Ritual für sichtbar mehr Glow.</p>" },
    { "type": "text", "id": "announcement_link_label", "label": "Announcement link label" },
    { "type": "url", "id": "announcement_link_url", "label": "Announcement link URL" },
    { "type": "color", "id": "announcement_bg_color", "label": "Announcement background color", "default": "#2B211D" },
    { "type": "color", "id": "announcement_text_color", "label": "Announcement text color", "default": "#FFFFFF" },
    { "type": "header", "content": "Header behavior" },
    { "type": "checkbox", "id": "enable_transparent_on_homepage", "label": "Enable transparent header on homepage", "default": true },
    { "type": "checkbox", "id": "enable_hide_on_scroll_down", "label": "Hide on scroll down", "default": true },
    { "type": "checkbox", "id": "enable_show_on_scroll_up", "label": "Show on scroll up", "default": true },
    { "type": "checkbox", "id": "enable_solid_after_scroll", "label": "Use solid background after scroll", "default": true },
    { "type": "range", "id": "scroll_threshold", "label": "Scroll threshold", "min": 20, "max": 300, "step": 10, "unit": "px", "default": 80 },
    { "type": "select", "id": "sticky_mode", "label": "Sticky mode", "options": [{ "value": "fixed", "label": "Fixed" }, { "value": "sticky", "label": "Sticky" }], "default": "fixed" },
    { "type": "header", "content": "Desktop layout" },
    { "type": "select", "id": "desktop_nav_position", "label": "Desktop nav position", "options": [{ "value": "left", "label": "Left" }, { "value": "center", "label": "Center" }], "default": "left" },
    { "type": "checkbox", "id": "show_search", "label": "Show search", "default": true },
    { "type": "checkbox", "id": "show_account", "label": "Show account", "default": true },
    { "type": "checkbox", "id": "show_cart", "label": "Show cart", "default": true },
    { "type": "checkbox", "id": "show_cart_count", "label": "Show cart count", "default": true },
    { "type": "header", "content": "Mobile" },
    { "type": "checkbox", "id": "mobile_logo_centered", "label": "Mobile logo centered", "default": true },
    { "type": "select", "id": "mobile_drawer_position", "label": "Mobile drawer position", "options": [{ "value": "left", "label": "Left" }, { "value": "right", "label": "Right" }], "default": "left" },
    { "type": "checkbox", "id": "show_mobile_search", "label": "Show mobile search", "default": true },
    { "type": "checkbox", "id": "show_mobile_account", "label": "Show mobile account", "default": true },
    { "type": "checkbox", "id": "show_mobile_promo_text", "label": "Show mobile promo text", "default": false },
    { "type": "richtext", "id": "mobile_promo_text", "label": "Mobile promo text", "default": "<p>Premium Skincare als ruhiges 3-Step Ritual.</p>" },
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "transparent_text_color", "label": "Transparent text color", "default": "#FFFFFF" },
    { "type": "color", "id": "solid_bg_color", "label": "Solid background color", "default": "#F7F1EA" },
    { "type": "color", "id": "solid_text_color", "label": "Solid text color", "default": "#2B211D" },
    { "type": "color", "id": "border_color", "label": "Border color", "default": "#E3D7CC" },
    { "type": "color", "id": "drawer_bg_color", "label": "Drawer background color", "default": "#F7F1EA" },
    { "type": "color", "id": "drawer_text_color", "label": "Drawer text color", "default": "#2B211D" },
    { "type": "color", "id": "accent_color", "label": "Accent color", "default": "#C9A88D" },
    { "type": "header", "content": "Style" },
    { "type": "range", "id": "header_height_desktop", "label": "Header height desktop", "min": 56, "max": 120, "step": 2, "unit": "px", "default": 76 },
    { "type": "range", "id": "header_height_mobile", "label": "Header height mobile", "min": 52, "max": 92, "step": 2, "unit": "px", "default": 64 },
    { "type": "checkbox", "id": "enable_blur_on_scroll", "label": "Enable blur on scroll", "default": true },
    { "type": "checkbox", "id": "enable_bottom_border", "label": "Enable bottom border", "default": false },
    { "type": "checkbox", "id": "enable_soft_shadow", "label": "Enable soft shadow", "default": false },
    { "type": "range", "id": "nav_letter_spacing", "label": "Nav letter spacing", "min": 0, "max": 40, "step": 1, "unit": "px", "default": 8 },
    { "type": "range", "id": "nav_font_size", "label": "Nav font size", "min": 10, "max": 18, "step": 1, "unit": "px", "default": 15 }
  ],
  "blocks": [
    { "type": "mega_category", "name": "Mega menu category", "settings": [
      { "type": "text", "id": "title", "label": "Category title", "default": "Ritual Sets" },
      { "type": "collection", "id": "collection", "label": "Fallback collection" },
      { "type": "url", "id": "category_link", "label": "Category CTA link" },
      { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Kategorie ansehen" },
      { "type": "text", "id": "fallback_badge", "label": "Fallback product badge", "default": "ADORA" },
      { "type": "product", "id": "product_1", "label": "Product 1" },
      { "type": "text", "id": "product_1_badge", "label": "Product 1 badge", "default": "Bestseller" },
      { "type": "product", "id": "product_2", "label": "Product 2" },
      { "type": "text", "id": "product_2_badge", "label": "Product 2 badge", "default": "Glow" },
      { "type": "product", "id": "product_3", "label": "Product 3" },
      { "type": "text", "id": "product_3_badge", "label": "Product 3 badge" },
      { "type": "product", "id": "product_4", "label": "Product 4" },
      { "type": "text", "id": "product_4_badge", "label": "Product 4 badge" }
    ] },
    { "type": "utility_link", "name": "Utility link", "settings": [{ "type": "text", "id": "label", "label": "Label", "default": "Ritual" }, { "type": "url", "id": "url", "label": "URL" }, { "type": "checkbox", "id": "show_desktop", "label": "Show desktop", "default": true }, { "type": "checkbox", "id": "show_mobile", "label": "Show mobile", "default": true }] },
    { "type": "drawer_promo_link", "name": "Drawer promo link", "settings": [{ "type": "text", "id": "label", "label": "Label", "default": "Glass Skin Ritual entdecken" }, { "type": "url", "id": "url", "label": "URL" }] }
  ],
  "presets": [{ "name": "ADORA Header", "blocks": [
    { "type": "mega_category", "settings": { "title": "Ritual Sets", "cta_label": "Alle Sets ansehen" } },
    { "type": "mega_category", "settings": { "title": "Cleanser", "cta_label": "Cleanser ansehen" } },
    { "type": "mega_category", "settings": { "title": "Moisture", "cta_label": "Pflege ansehen" } },
    { "type": "mega_category", "settings": { "title": "Finish", "cta_label": "Finish ansehen" } }
  ] }]
}
{% endschema %}
