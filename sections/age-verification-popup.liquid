<link rel="stylesheet" href="{{ 'component-age-verification-popup.css' | asset_url }}" media="print" fetchpriority="low" onload="this.media='all'">
<noscript>{{ 'component-age-verification-popup.css' | asset_url | stylesheet_tag }}</noscript>

{% liquid
  assign logo = section.settings.age_verification_logo
  assign logo_width = section.settings.age_verification_logo_width
  assign logo_mg_bottom = section.settings.age_verification_logo_mg_bottom
  assign title = section.settings.age_verification_popup_title
  assign title_color = section.settings.age_verification_popup_title_color
  assign title_font_size = section.settings.age_verification_title_font_size
  assign title_mg_bottom = section.settings.age_verification_title_mg_bottom
  assign desc = section.settings.age_verification_popup_desc
  assign desc_color = section.settings.age_verification_popup_desc_color
  assign desc_font_size = section.settings.age_verification_desc_font_size
  assign eligible_label = section.settings.age_verification_eligible
  assign not_eligible_label = section.settings.age_verification_not_eligible
  assign not_eligible_link = section.settings.not_eligible_link
  assign content_actions_gap = section.settings.content_actions_gap
  assign content_actions_gap_mobile = section.settings.content_actions_gap_mobile

  if logo != blank
    assign logo_alt = logo.alt | default: shop.name | escape
    assign logo_image_class = 'age-verification-popup__logo-image'
    assign logo_sizes = logo_width | append: 'px'
  endif
%}

<age-verification-popup
  class="modal--popup age-verification-popup fixed top-0 left-0 z-9 w-screen h-full flex-center no-js-hidden"
  element-s-popup
  id="Age-verification-popup-{{ section.id }}"
  data-expire="{{ section.settings.age_verification_popup_expire }}"
  data-delay="{{ section.settings.popup_delay | times: 1000 }}"
  tabindex="-1"
>
  <div id="Drawer-Overlay-Age-{{ section.id }}" class="drawer__overlay fixed inset-0" aria-hidden="true"></div>
  <div
    class="popup__inner age-verification-popup-wrapper global-settings-popup color-{{ section.settings.color_scheme }} text-center cus-scrollbar"
    role="dialog"
    aria-modal="true"
    aria-label="{{ title | default: 'Age verification' | escape }}"
    style="
      --modal-max-width: 100rem;
      --modal-max-height: min(100%, 90vh);
      --age-verification-logo-width: {{ logo_width }}px;
      --age-verification-logo-mg-bottom: {{ logo_mg_bottom }}px;
      --age-verification-title-color: {{ title_color }};
      --age-verification-title-font-size: {{ title_font_size }};
      --age-verification-title-mg-bottom: {{ title_mg_bottom }}px;
      --age-verification-desc-color: {{ desc_color }};
      --age-verification-desc-font-size: {{ desc_font_size }};
      --age-verification-content-actions-gap: {{ content_actions_gap }}px;
      --age-verification-content-actions-gap-mobile: {{ content_actions_gap_mobile }}px;
      --p: 5rem 1rem;
    "
  >
    <div class="age-verification-popup__content">
      {%- if logo != blank -%}
        <div class="age-verification-popup__logo">
          {{
            logo
            | image_url: width: logo_width
            | image_tag:
              widths: '100, 200, 300, 400',
              width: logo_width,
              alt: logo_alt,
              class: logo_image_class,
              sizes: logo_sizes,
              loading: 'lazy',
              fetchpriority: 'low'
          }}
        </div>
      {%- endif -%}

      {%- if title != blank -%}
        <h2 class="age-verification-popup__heading h2">{{ title }}</h2>
      {%- endif -%}

      {%- if desc != blank -%}
        <div class="age-verification-popup__description rte">{{ desc }}</div>
      {%- endif -%}
    </div>

    <div class="age-verification-popup__actions">
      {%- if not_eligible_label != blank -%}
        <a class="button-secondary age-verification-popup__button age-verification-popup__button--decline" href="{{ not_eligible_link }}">
          {{ not_eligible_label }}
        </a>
      {%- endif -%}
      {%- if eligible_label != blank -%}
        <button
          type="button"
          class="button age-verification-popup__button age-verification-popup__button--confirm"
          data-age-verification-confirm
        >
          {{ eligible_label }}
        </button>
      {%- endif -%}
    </div>
  </div>
</age-verification-popup>

<script src="{{ 'age-verification-popup.js' | asset_url }}" defer="defer"></script>

